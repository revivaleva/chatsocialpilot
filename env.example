# OpenAI API設定
OPENAI_API_KEY=sk-dummy-key-replace-with-your-actual-openai-api-key-1234567890abcdef

# タイムゾーン設定
TZ=Asia/Tokyo

# ダッシュボード設定（オプション）
DASHBOARD_PORT=5173

# Container Browser設定（オプション）
CONTAINER_EXPORT_HOST=127.0.0.1
CONTAINER_EXPORT_PORT=3001

# デバッグ設定（オプション）
# DEBUG=1
# LOG_LEVEL=debug

# Container Browser認証（オプション）
# REMOTE_EXEC_HMAC=your-hmac-secret-here
