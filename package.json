{
  "name": "social-bot",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node --transpile-only src/run.ts",
    "dev:tsx": "tsx src/run.ts",
    "smoke": "tsx scripts/smoke.ts",
    "start": "node dist/run.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"(placeholder) add tests later\" && exit 0",
    "bench": "ts-node --transpile-only scripts/bench.ts"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "tsx": "^3.12.7"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "node-cron": "^3.0.3",
    "openai": "^4.58.0",
    "playwright": "^1.48.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8",
    "express": "^4.18.2"
  }
}
